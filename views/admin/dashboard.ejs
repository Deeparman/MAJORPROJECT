<% layout("/layouts/boilerplate") %>

  <div class="admin-shell">
    <aside class="admin-sidebar" aria-label="Admin navigation">
      <div class="admin-logo">
        <span class="admin-logo-mark"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
        <span class="admin-logo-text">Wanderlust Admin</span>
      </div>

      <nav class="admin-nav">
        <a href="/admin" class="admin-nav-link active">
          <i class="fa-solid fa-gauge-high"></i>
          <span>Dashboard</span>
        </a>
        <a href="/admin/all-users" class="admin-nav-link">
          <i class="fa-solid fa-users"></i>
          <span>Users</span>
        </a>
        <a href="/admin/approvals" class="admin-nav-link">
          <i class="fa-solid fa-hourglass-half"></i>
          <span>Pending Approvals</span>
        </a>
        <a href="/listings" class="admin-nav-link">
          <i class="fa-solid fa-store"></i>
          <span>Listings</span>
        </a>
        <a href="/admin/reviews" class="admin-nav-link">
          <i class="fa-solid fa-star"></i>
          <span>Reviews</span>
        </a>
        <a href="/admin/all-bookings" class="admin-nav-link">
          <i class="fa-solid fa-calendar-check"></i>
          <span>Bookings</span>
        </a>
      </nav>




      <div class="admin-sidebar-footer">
        <div class="admin-chip">
          <i class="fa-solid fa-shield-halved"></i>
          <span>Admin</span>
        </div>
      </div>
    </aside>

    <main class="admin-main">
      <header class="admin-topbar">
        <div class="admin-topbar-title">
          <h2 class="mb-0">Dashboard Overview</h2>
          <div class="admin-subtitle">Monitor users, listings, and approvals in one place</div>
        </div>

        <div class="admin-topbar-actions">
          <div class="admin-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="adminSearch" class="form-control" placeholder="Search in dashboard..."
              aria-label="Search in dashboard" />
          </div>
        </div>

      </header>

      <section class="stats-grid" aria-label="Dashboard stats">
        <div class="stat-card">
          <div class="stat-card-head">
            <span class="stat-icon"><i class="fa-solid fa-users"></i></span>
            <h6 class="mb-1">Total Users</h6>
          </div>
          <div class="stat-value">
            <%= users.length %>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-card-head">
            <span class="stat-icon"><i class="fa-solid fa-store"></i></span>
            <h6 class="mb-1">Total Listings</h6>
          </div>
          <div class="stat-value">
            <%= listings.length %>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-card-head">
            <span class="stat-icon stat-icon-warn"><i class="fa-solid fa-clock"></i></span>
            <h6 class="mb-1">Pending Listings</h6>
          </div>
          <div class="stat-value">
            <%= listings.filter(l=> l.status === "pending").length %>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-card-head">
            <span class="stat-icon stat-icon-violet"><i class="fa-solid fa-user-tie"></i></span>
            <h6 class="mb-1">Hotel Owners</h6>
          </div>
          <div class="stat-value">
            <%= users.filter(u=> u.role === "hotelOwner").length %>
          </div>
        </div>
      </section>

      <section class="admin-grid">
        <div class="dashboard-card" id="users">
          <div class="dashboard-card-head">
            <h4 class="mb-0">User Management</h4>
            <div class="dashboard-card-meta">
              <span class="badge bg-light text-dark border">
                <%= users.length %> users
              </span>
            </div>
          </div>

          <div class="table-responsive admin-table-wrap">
            <table class="table table-hover align-middle admin-table" aria-label="Users table">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Listings</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody id="usersTbody">
                <% users.forEach(user=> { %>
                  <tr class="admin-row"
                    data-search="<%= (user.username + ' ' + user.email + ' ' + user.role).toLowerCase() %>">
                    <td>
                      <div class="admin-user">
                        <span class="admin-avatar">
                          <%= (user.username || '?' ).trim().slice(0,1).toUpperCase() %>
                        </span>
                        <div class="admin-user-meta">
                          <div class="admin-username">
                            <%= user.username %>
                          </div>
                          <div class="admin-user-sub muted">ID: <%= user._id.toString().slice(-6) %>
                          </div>
                        </div>
                      </div>
                    </td>
                    <td class="admin-email">
                      <%= user.email %>
                    </td>
                    <td>
                      <span
                        class="badge role-badge <%= user.role === 'admin' ? 'role-admin' : (user.role === 'hotelOwner' ? 'role-owner' : 'role-user') %>">
                        <%= user.role %>
                      </span>
                    </td>
                    <td>
                      <%= listings.filter(l=> l.owner && l.owner.toString() === user._id.toString()).length %>
                    </td>
                    <td class="text-end">
                      <% const hasListings=listings.some(l=> l.owner && l.owner.toString() === user._id.toString()); %>

                        <% if(user.role==="user" && hasListings){ %>
                          <form method="POST" action="/admin/make-owner/<%= user._id %>?_method=PATCH" class="d-inline">
                            <button class="btn btn-success btn-sm admin-action-btn">
                              <i class="fa-solid fa-user-tie"></i>
                              <span class="ms-1">Make Owner</span>
                            </button>
                          </form>
                          <% } %>

                            <% if(user.role !=="admin" ){ %>
                              <form method="POST" action="/admin/make-user/<%= user._id %>?_method=PATCH"
                                class="d-inline">
                                <button class="btn btn-outline-danger btn-sm admin-action-btn">
                                  <i class="fa-solid fa-rotate-left"></i>
                                  <span class="ms-1">Reset</span>
                                </button>
                              </form>
                              <% } %>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <aside class="dashboard-card" id="approvals">
          <div class="dashboard-card-head">
            <h4 class="mb-0">Pending Approvals</h4>
            <div class="dashboard-card-meta">
              <span class="badge bg-danger">Pending: <%= listings.filter(l=> l.status === 'pending').length %></span>
            </div>
          </div>

          <% const pendingListings=listings.filter(l=> l.status === "pending"); %>

            <% if(pendingListings.length===0){ %>
              <div class="empty-state">
                <div class="empty-icon"><i class="fa-regular fa-circle-check"></i></div>
                <div class="empty-title">All set</div>
                <div class="empty-sub">No pending listings</div>
              </div>
              <% } else { %>
                <div class="pending-list" id="pendingList">
                  <% pendingListings.forEach(l=> { %>
                    <div class="pending-item admin-row"
                      data-search="<%= (l.title + ' ' + (l.location||'') + ' ' + (l.category||'') + ' ' + l.status).toLowerCase() %>">
                      <div class="pending-item-thumb">
                        <img src="<%= l.image?.url || '/images/placeholder.png' %>" alt="Listing image" />
                      </div>
                      <div class="pending-item-body">
                        <div class="pending-item-title">
                          <%= l.title %>
                        </div>
                        <div class="pending-item-meta">
                          <span class="meta-pill"><i class="fa-solid fa-location-dot"></i>
                            <%= l.location || '-' %>
                          </span>
                          <span class="meta-pill"><i class="fa-solid fa-layer-group"></i>
                            <%= l.category || '-' %>
                          </span>
                        </div>
                        <div class="pending-item-status">
                          <span class="badge bg-warning text-dark">
                            <%= l.status %>
                          </span>
                        </div>
                      </div>
                      <div class="pending-item-action">
                        <form method="POST" action="/admin/listings/<%= l._id %>/approve?_method=PATCH">
                          <button class="btn btn-success btn-sm admin-action-btn w-100">
                            <i class="fa-solid fa-check"></i>
                            <span class="ms-1">Approve</span>
                          </button>
                        </form>
                        <form method="POST" action="/admin/listings/<%= l._id %>/reject?_method=PATCH"
                          class="flex-fill">
                          <button class="btn btn-danger btn-sm admin-action-btn w-100">
                            <i class="fa-solid fa-xmark"></i>
                            <span class="ms-1">Reject</span>
                          </button>
                        </form>

                      </div>
                    </div>
                    <% }) %>
                </div>
                <% } %>
        </aside>
      </section>
    </main>
  </div>

  <script>
    (function () {
      const input = document.getElementById('adminSearch');
      if (!input) return;

      const rows = Array.from(document.querySelectorAll('.admin-row'));
      const apply = () => {
        const q = (input.value || '').trim().toLowerCase();
        for (const row of rows) {
          const hay = (row.getAttribute('data-search') || '').toLowerCase();
          row.style.display = !q || hay.includes(q) ? '' : 'none';
        }
      };
      input.addEventListener('input', apply);
    })();
  </script>