<% layout("/layouts/boilerplate") %>

<div class="admin-container">
<!-- Sidebar -->
<div class="admin-sidebar">

    <div class="admin-logo">
        Wanderlust Admin
    </div>

    <a href="/admin" class="active">Dashboard</a>
    <a href="/admin/all-users">Users</a>
    <a href="/admin/approvals">Pending Approvals</a>
    <a href="/listings">Listings</a>
    <a href="/admin/reviews">Reviews</a>
    <a href="/admin/all-bookings">Bookings</a>


</div>

<!-- Main Content -->
<div class="admin-main">

    <h2 class="mb-4">Dashboard Overview</h2>

    <!-- Stats -->
    <div class="stats-grid">

        <div class="stat-card">
            <h6>Total Users</h6>
            <h2><%= users.length %></h2>
        </div>

        <div class="stat-card">
            <h6>Total Listings</h6>
            <h2><%= listings.length %></h2>
        </div>

        <div class="stat-card">
            <h6>Pending Listings</h6>
            <h2>
                <%= listings.filter(l => l.status === "pending").length %>
            </h2>
        </div>

        <div class="stat-card">
            <h6>Hotel Owners</h6>
            <h2>
                <%= users.filter(u => u.role === "hotelOwner").length %>
            </h2>
        </div>

    </div>

    <!-- Main Row -->
    <div class="row">

        <!-- User Management -->
        <div class="col-lg-8 mb-4">

            <div class="dashboard-card" id="users">

                <h4 class="mb-3">User Management</h4>

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Listings</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% users.forEach(user => { %>

                            <tr>

                                <td><%= user.username %></td>

                                <td><%= user.email %></td>

                                <td>
                                    <span class="badge bg-secondary">
                                        <%= user.role %>
                                    </span>
                                </td>

                                <td>
                                    <%= listings.filter(l =>
                                        l.owner &&
                                        l.owner.toString() === user._id.toString()
                                    ).length %>
                                </td>

                                <td>

                                    <% const hasListings = listings.some(l =>
                                        l.owner &&
                                        l.owner.toString() === user._id.toString()
                                    ); %>

                                    <% if(user.role === "user" && hasListings){ %>

                                    <form
                                        method="POST"
                                        action="/admin/make-owner/<%= user._id %>?_method=PATCH"
                                        style="display:inline"
                                    >
                                        <button class="btn btn-success btn-sm">
                                            Make Owner
                                        </button>
                                    </form>

                                    <% } %>

                                    <% if(user.role !== "admin"){ %>

                                    <form
                                        method="POST"
                                        action="/admin/make-user/<%= user._id %>?_method=PATCH"
                                        style="display:inline"
                                    >
                                        <button class="btn btn-outline-danger btn-sm">
                                            Reset
                                        </button>
                                    </form>

                                    <% } %>

                                </td>

                            </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- Pending Approvals -->
        <div class="col-lg-4">

            <div class="dashboard-card" id="approvals">

                <h4 class="mb-3">Pending Approvals</h4>

                <% const pendingListings = listings.filter(
                    l => l.status === "pending"
                ); %>

                <% if(pendingListings.length === 0){ %>

                    <div class="alert alert-light">
                        No pending listings
                    </div>

                <% } else { %>

                    <% pendingListings.forEach(l => { %>

                    <div class="border rounded p-3 mb-3">

                        <h6><%= l.title %></h6>

                        <small class="text-muted">
                            Status: <%= l.status %>
                        </small>

                        <div class="mt-2">

                            <form
                                method="POST"
                                action="/admin/listings/<%= l._id %>/approve?_method=PATCH"
                            >
                                <button class="btn btn-success btn-sm">
                                    Approve
                                </button>
                            </form>

                        </div>

                    </div>

                    <% }) %>

                <% } %>

            </div>

        </div>

    </div>

</div>
</div>
